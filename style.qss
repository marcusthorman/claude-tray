/* HUD overlay — Catppuccin Mocha base, CachyOS-flavored teal accent. */

QWidget {
    font-family: "Inter", "Noto Sans", "Cantarell", sans-serif;
    color: #cdd6f4;
}

#Hud {
    background: transparent;
}

#HudBrand {
    color: #d97757;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 2px;
}

#HudPlan {
    color: #cdd6f4;
    background-color: rgba(49, 50, 68, 200);
    border-radius: 6px;
    padding: 1px 6px;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.6px;
}

#HudRemain {
    color: #94e2d5;
    font-size: 11px;
    font-weight: 600;
}

#HudMeta {
    color: #a6adc8;
    font-size: 10px;
    font-weight: 500;
}

#HudRowLead {
    color: #7f849c;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 1px;
}

#HudRowTrail {
    color: #a6adc8;
    font-size: 10px;
    font-weight: 500;
}

QProgressBar#HudBar,
QProgressBar#HudBarWarn,
QProgressBar#HudBarDanger {
    background-color: rgba(49, 50, 68, 200);
    border: none;
    border-radius: 3px;
    max-height: 5px;
    min-height: 5px;
}

QProgressBar#HudBar::chunk        { background-color: #94e2d5; border-radius: 3px; }
QProgressBar#HudBarWarn::chunk    { background-color: #f9e2af; border-radius: 3px; }
QProgressBar#HudBarDanger::chunk  { background-color: #f38ba8; border-radius: 3px; }

QMenu {
    background-color: #1e1e2e;
    color: #cdd6f4;
    border: 1px solid #45475a;
    border-radius: 8px;
    padding: 4px;
    font-size: 11px;
}

QMenu::item {
    padding: 5px 14px;
    border-radius: 4px;
}

QMenu::item:selected {
    background-color: #313244;
}

QMenu::separator {
    height: 1px;
    background: #313244;
    margin: 4px 6px;
}

#MenuLabel {
    color: #cdd6f4;
    font-size: 11px;
}

QSlider::groove:horizontal {
    background: #313244;
    height: 4px;
    border-radius: 2px;
}
QSlider::handle:horizontal {
    background: #94e2d5;
    width: 12px;
    height: 12px;
    margin: -5px 0;
    border-radius: 6px;
}
QSlider::sub-page:horizontal {
    background: #94e2d5;
    border-radius: 2px;
}
